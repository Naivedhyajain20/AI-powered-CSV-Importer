{
  "name": "csv-importer-api",
  "version": "1.0.0",
  "description": "Production-ready backend skeleton for AI-powered CSV Importer",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsnd --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "client:dev": "npm run dev --prefix frontend",
    "client:build": "npm run build --prefix frontend",
    "client:start": "npm run start --prefix frontend",
    "lint": "eslint 'src/**/*.ts'",
    "format": "prettier --write 'src/**/*.ts'",
    "test": "jest"
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "multer": "^1.4.5-lts.1",
    "papaparse": "^5.4.1",
    "pino": "^9.0.0",
    "pino-pretty": "^11.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.12.7",
    "@types/papaparse": "^5.3.14",
    "@typescript-eslint/eslint-plugin": "^7.7.0",
    "@typescript-eslint/parser": "^7.7.0",
    "eslint": "^8.57.0",
    "jest": "^30.4.2",
    "playwright": "^1.61.1",
    "prettier": "^3.2.5",
    "ts-jest": "^29.4.11",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "private": true
}
